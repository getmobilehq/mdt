SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
AWS_REGION=eu-west-2

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Follow-up notifications — WhatsApp provider switch.
#   twilio (default) — Meta-approved Business templates. Production.
#   openwa           — @open-wa/wa-automate REST server. Concept testing only.
WHATSAPP_PROVIDER=twilio

# --- Twilio Business API (WHATSAPP_PROVIDER=twilio) ---
# All five required for sends to fire. Missing TEMPLATE SIDs → reminder row is
# still written but no message dispatched (audit records delivered=false).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_TEMPLATE_SID_OVERDUE=
TWILIO_TEMPLATE_SID_DUE_SOON=

# --- open-wa/wa-automate (WHATSAPP_PROVIDER=openwa) ---
# REST server URL + its --key. See services/mdt-whatsapp-dev/README.md.
# OPENWA_API_URL unset → reminder row written, no send (delivered=false).
OPENWA_API_URL=http://localhost:8002
OPENWA_API_KEY=
